# =============================================================================
# gmo-bot-safe 環境変数サンプル
# -----------------------------------------------------------------------------
# .env にコピーして使う。 `.env` は Git にコミットしないこと（.gitignore 済み）。
# dry-run 中は GMO_API_* はダミーのままで問題ない。
# =============================================================================

# --- 稼働モード --------------------------------------------------------------
# dry_run | live   （現段階は必ず dry_run。live は未実装・封印中）
RUN_MODE=dry_run

# --- GMOコイン API -----------------------------------------------------------
# live 時に必要。dry_run ではダミー文字列でよい。
GMO_API_KEY=your_api_key_here
GMO_API_SECRET=your_api_secret_here

# --- live 発注の三段ゲート ---------------------------------------------------
# gate1: src/order_executor.py の ENABLE_LIVE_ORDER (コード定数)
#        → .env では変更不可。PR で明示的に書き換える必要あり。
# gate2: 下記の LIVE_OK (環境変数)  → 'yes' でのみ通過
# gate3: src/order_executor.py の _send_live_order()  → 現状 NotImplementedError
#
# さらに scripts/run_live.sh は CONFIRM_LIVE=yes がなければ起動しない。
# 現段階では LIVE_OK / CONFIRM_LIVE は必ず no（または未設定）のまま。
LIVE_OK=no
CONFIRM_LIVE=no

# --- 通知 --------------------------------------------------------------------
# Slack / Discord の incoming webhook URL
NOTIFIER_WEBHOOK_URL=

# --- ログ・状態保存先 / 設定ファイルパス -------------------------------------
LOG_LEVEL=INFO

# 重要: 以下の 3 変数 (LOG_DIR / STATE_DIR / CONFIG_PATH) は systemd の
# `EnvironmentFile=` から読まれた値が `Environment=` ディレクティブを上書き
# する仕様 (systemd v245+) のため、本番 (Oracle Cloud) では .env では指定せず
# `deploy/*.service` の Environment= 行に任せる。
#
# 以下の 3 行は **shell 単発起動** (例: `bash scripts/dry_run.sh` /
# `dry_run_compare.sh`、または python src/main.py を直叩き) でのみ有効。
# 並走 (compare-old) と同居する systemd 構成では絶対にコメントアウトしておく。
#LOG_DIR=./logs
#STATE_DIR=./data
#CONFIG_PATH=./config/strategies/btc_eth_balanced_ndx.yaml

# --- STOP ファイル -----------------------------------------------------------
# このファイルが存在する間、新規注文は停止される。
# 例: `touch ./STOP` で手動停止、`rm ./STOP` で再開可能状態に戻す。
STOP_FILE=./STOP
